# Next.js сайт — переменные окружения (скопируй в web/.env)

# --- База данных ---
# локально (docker-compose): пользователь/пароль/база = yastrub
DATABASE_URL="postgresql://yastrub:yastrub@localhost:5432/yastrub?schema=public"

# --- Публичный адрес сайта (для QR, ссылок, вебхуков) ---
# локально: http://localhost:3000 ; на проде: https://yastrub.academy
APP_URL="http://localhost:3000"

# --- Telegram (бот доступу до курсів) ---
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
TELEGRAM_BOT_USERNAME="yastrub_bot"   # без @, для ссылки t.me/<username>?start=...

# --- Telegram (бот ADMIN YASTRUB — заявки з сайту) ---
# ADMIN_BOT_TOKEN — токен від @BotFather для бота ADMIN YASTRUB
# ADMIN_CHAT_ID   — куди слати заявки (твій chat id або id групи/каналу)
ADMIN_BOT_TOKEN=""
ADMIN_CHAT_ID=""

# --- monobank ---
# Способ A (простой): банка (jar)
MONO_JAR_URL="https://send.monobank.ua/jar/XXXXXXXX"
# Способ B (эквайринг мерчанта): если задан токен — сайт создаёт invoice и слушает вебхук
# MONO_ACQUIRING_TOKEN="uXXXXXXXXXXXXXXXX"

# --- Админка ---
ADMIN_TOKEN="change-me-to-a-long-random-string"
